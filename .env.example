# ═══════════════════════════════════════════════════════════════
# Deep Paper Reader — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# DeepSeek API (무료 tier)
# 발급: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Google Gemini API (무료 tier — fallback용)
# 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza-your-google-key

# Zotero API
# API Key 발급: https://www.zotero.org/settings/keys
# Library ID 확인: 같은 페이지에서 "Your userID for API calls"
ZOTERO_API_KEY=your-zotero-api-key
ZOTERO_LIBRARY_ID=your-zotero-user-id
